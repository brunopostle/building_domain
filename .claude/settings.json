{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bsos export --format json --output data/bsos_snapshot.json --db bsos.db 2>/dev/null || true",
            "statusMessage": "Updating bsos_snapshot.json…"
          }
        ]
      }
    ]
  }
}